# SpiritOS server env

PORT=3001
NODE_ENV=development

# Prisma — SQLite for dev. Switch to "postgresql://..." + update
# prisma/schema.prisma to use Postgres in production.
DATABASE_URL=file:./savitaos.db

# REQUIRED. Long random string for express-session.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Filesystem root for the File Explorer app. Empty defaults to the user's
# home directory. Set to ./demo-filesystem to use the bundled demo data.
FS_ROOT=
MAX_TREE_DEPTH=4
TREE_CACHE_TTL=5000

# Terminal limits
TERMINAL_TIMEOUT=15000
TERMINAL_MAX_OUTPUT=50000
# Set to true on a public/demo deployment to skip terminal auth requirement.
# Set to false (or leave unset) for production multi-user installs.
TERMINAL_ALLOW_DEMO=true

# CORS
CLIENT_URL=http://localhost:5173

# ─── IRIS Engine (Primary AI — Gemini) ──────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: Groq for faster intent routing
GROQ_API_KEY=

# Optional: Tavily for web search
TAVILY_API_KEY=

# Optional: OpenRouter for free-model fallback (https://openrouter.ai/)
# Uses 9+ free LLMs as fallback when Gemini hits rate limits
OPENROUTER_API_KEY=

# Engine config
AI_PRIMARY_ENGINE=iris           # 'iris' (Gemini primary) or 'spirit' (offline only)
AI_FALLBACK_TIMEOUT_MS=10000     # Fall back after this many ms
ENABLE_PERSISTENT_MEMORY=true    # Store user memories across sessions
AI_ENGINE_ORDER=gemini,sarvam,openrouter,spirit
AI_PREFER_SARVAM_FOR_INDIC=true

# FALLBACK CHAIN: Gemini → Sarvam → OpenRouter free models → Spirit offline
# Without any API keys, the system uses the offline Spirit engine (lib/spirit.js).

# ── Sarvam AI (Indian-language voice + LLM) ──────────────────────────────────
# Get your key from https://console.sarvam.ai
SARVAM_API_KEY=
SARVAM_ENABLED=false         # master switch; when false, app uses Web Speech + existing engines
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_TTS_SPEAKER=          # valid bulbul:v2 speaker id (e.g. meera, arvind — confirm from docs)

# ── Gemini control (engine is always present; GEMINI_ENABLED=false skips tier 1) ──
GEMINI_ENABLED=true

# ── Mem0 Long-Term Memory (https://mem0.ai) ─────────────────────────────────
# Get your key from https://app.mem0.ai — free tier available.
# Without this key the system uses a local JSON store at server/data/memories/
# (offline fallback — Spirit OS works with zero internet).
MEM0_API_KEY=

# ── Gnani AI Voice (hackathon partner — https://app.gnani.ai/voice) ──────────
# Indian-language STT (Prisma v2.5) + TTS (vachana-voice-v3).
# Used as automatic fallback tier for /api/voice/stt and /api/voice/tts when
# Sarvam is disabled or fails. Setting the key enables it — no other switch.
GNANI_API_KEY=
GNANI_BASE_URL=https://api.vachana.ai
GNANI_TTS_VOICE=Riya          # Karan | Simran | Nara | Riya | Viraj | Raju
GNANI_TIMEOUT_MS=15000
