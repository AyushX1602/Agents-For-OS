{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://spiritos.onrender.com/api/:path*"
    },
    {
      "source": "/how-to/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
